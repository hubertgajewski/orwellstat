# Populated-account credentials (default). Used by every authenticated test that does not
# explicitly opt into the empty account via `test.use({ storageState: EMPTY_STORAGE_STATE })`
# or `test.use({ authAccount: 'empty' })`.
ORWELLSTAT_USER=
ORWELLSTAT_PASSWORD=
# Empty-account credentials. Required for tests asserting empty-state UI (e.g. the
# "no data in the last 30 days" message on /zone/). Do not log in to this account manually
# — any hit visit makes the empty-state assertions silently fail.
ORWELLSTAT_USER_EMPTY=
ORWELLSTAT_PASSWORD_EMPTY=
# Real email currently stored on the populated account. Anchors the
# zone-admin mutating-settings tests so they recover when a prior run's
# afterEach did not complete (see #397). Value must match the live email.
ORWELLSTAT_EMAIL=
# Target environment for Playwright. Accepted values: production (default), staging.
# ENV=staging also requires BASIC_AUTH_USER / BASIC_AUTH_PASSWORD below.
ENV=
# Required only for staging (https://stage.orwellstat.hubertgajewski.com).
# If BASIC_AUTH_USER is set but BASIC_AUTH_PASSWORD is omitted, Playwright
# will silently send an empty password and all requests will return 401.
BASIC_AUTH_USER=
BASIC_AUTH_PASSWORD=
# Shared-secret token for /scripts/drain.php (the test-only ingest-flush endpoint).
# fireTrackingHit POSTs to drain.php with X-Orwellstat-Test-Token: <this value> so
# the hit log is flushed into the DB before the caller asserts. Server side, the
# token lives at ~/.private/orwellstat_drain_token.php on stage and prod and must
# match this value. Empty here = every fireTrackingHit-using spec fails fast.
ORWELLSTAT_DRAIN_TOKEN=
# Optional: AI-powered test failure diagnosis (requires AI_DIAGNOSIS=true in .vars).
# When absent the fixture behaves exactly as without it — no extra attachments, no errors.
# Set AI_PROVIDER in .vars to choose which provider to use (default: anthropic).
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
# Required when ANTHROPIC_BASE_URL points to OpenRouter (or any Anthropic-compat proxy).
# Used as the Bearer auth token for the PR reviewer. Get one at https://openrouter.ai/keys.
OPENROUTER_API_KEY=
