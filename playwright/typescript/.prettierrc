{
  "semi": true,
  "singleQuote": true,
  "printWidth": 100,
  "tabWidth": 2,
  "trailingComma": "es5",
  "plugins": ["@prettier/plugin-xml"],
  "xmlWhitespaceSensitivity": "preserve",
  "overrides": [
    {
      "files": ["*.xhtml"],
      "options": {
        "parser": "xml"
      }
    }
  ]
}
