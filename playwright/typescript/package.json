{
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@axe-core/playwright": "^4.12.1",
    "@google/generative-ai": "^0.24.1",
    "@playwright/test": "1.62.0-alpha-2026-07-07",
    "@prettier/plugin-xml": "^3.4.2",
    "@types/node": "^26.1.0",
    "@types/pngjs": "^6.0.5",
    "csstree-validator": "^4.0.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.9.4",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tsc": "tsc --noEmit",
    "test:unit": "node --test --experimental-strip-types --disable-warning=ExperimentalWarning 'utils/**/*.test.ts' 'scripts/**/*.test.ts'",
    "verify:matrix": "node --experimental-strip-types --disable-warning=ExperimentalWarning scripts/verify-coverage-matrix.ts",
    "prepare": "cd ../.. && husky playwright/typescript/.husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md,yml,yaml,html,xhtml}": "prettier --write"
  },
  "overrides": {
    "playwright-core": "1.62.0-alpha-2026-07-07"
  },
  "type": "module"
}
