{
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@axe-core/playwright": "^4.11.2",
    "@google/generative-ai": "^0.24.1",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "tsc": "tsc --noEmit",
    "test:unit": "node --test --experimental-strip-types --disable-warning=ExperimentalWarning 'utils/**/*.test.ts'",
