# CI repository variables — loaded by Playwright via dotenv (local runs) and by act via --var-file (local CI).
# In real GitHub Actions these are set under Settings → Variables → Actions.
# Copy to .vars and set each variable to "true" to enable the corresponding workflow or feature.
# When absent or any other value the workflow job or feature is skipped.
CLAUDE_REVIEW=
PLAYWRIGHT_TYPESCRIPT=
BRUNO=
QUALITY_METRICS=
# AI-powered test failure diagnosis. Set to "true" to enable.
AI_DIAGNOSIS=
# AI provider for test failure diagnosis. Accepted values: anthropic (default), gemini.
AI_PROVIDER=
# Deprecated: still works as a fallback for AI_DIAGNOSIS. Prefer AI_DIAGNOSIS above.
CLAUDE_DIAGNOSIS=
# Default runner for all workflow jobs. Set to "self-hosted" to route all jobs to the local
# self-hosted runner when the runner input is not explicitly set. Leave empty to use ubuntu-latest.
RUNNER=
