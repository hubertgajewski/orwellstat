meta {
  name: Login with valid credentials
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/zone/
  body: formUrlEncoded
  auth: none
}

script:pre-request {
  const user = bru.getEnvVar('BASIC_AUTH_USER');
  const pass = bru.getEnvVar('BASIC_AUTH_PASSWORD');
  if (user) {
    req.setHeader('Authorization', 'Basic ' + btoa(user + ':' + pass));
  }
}

headers {
  Content-Type: application/x-www-form-urlencoded
}

body:form-urlencoded {
  username: {{ORWELLSTAT_USER}}
  password: {{ORWELLSTAT_PASSWORD}}
  option: login
}

tests {
  test("returns 200 OK", function() {
    expect(res.status).to.equal(200);
  });
}
