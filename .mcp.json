{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"],
      "type": "stdio"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.68"],
      "type": "stdio"
    },
    "playwright-runner": {
      "command": "npx",
      "args": ["playwright-report-mcp@latest"],
      "type": "stdio"
    }
  }
}
