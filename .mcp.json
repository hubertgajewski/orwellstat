{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "docker",
      "args": ["mcp", "gateway", "run"],
      "type": "stdio"
    },
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@0.0.68"],
      "type": "stdio"
    },
    "playwright-report-mcp": {
      "command": "npx",
      "args": ["playwright-report-mcp@2.0.2"],
      "type": "stdio",
      "env": {
        "PW_DIR": "playwright/typescript"
      }
    },
    "quality-metrics": {
      "command": "node",
      "args": ["mcp/quality-metrics/dist/index.js"],
      "type": "stdio"
    }
  }
}
